# Server Configuration
PORT=5000

# MongoDB Connection
# For local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/dreamhotel

# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dreamhotel?retryWrites=true&w=majority

# JWT Secret Key (Change this to a secure random string in production)
JWT_SECRET=your_secret_key_here
